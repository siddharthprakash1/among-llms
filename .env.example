# Among LLMs runs with ZERO setup using the built-in deterministic `mock` brain.
# Everything below is OPTIONAL — add keys/endpoints to seat real models at the table.

# --- OpenAI-compatible (OpenAI, OpenRouter, Together, LM Studio, etc.) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# Comma-separated model ids to expose in the arena:
# OPENAI_MODELS=gpt-4o-mini,gpt-4o

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6

# --- Ollama (local, free) ---
# Set the base URL to enable. Default port shown.
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODELS=llama3.1,qwen2.5,mistral
